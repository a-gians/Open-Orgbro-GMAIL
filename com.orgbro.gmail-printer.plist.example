<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.orgbro.gmail-printer</string>
    <key>ProgramArguments</key>
    <array>
        <string>/ABSOLUTE/PATH/TO/Open-Orgbro-GMAIL/.venv/bin/python3</string>
        <string>/ABSOLUTE/PATH/TO/Open-Orgbro-GMAIL/scripts/gmail_listener.py</string>
        <string>--watch</string>
        <string>--project-id</string>
        <string>YOUR_GOOGLE_CLOUD_PROJECT_ID</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/Open-Orgbro-GMAIL</string>
    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/Open-Orgbro-GMAIL/logs/gmail_listener.log</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/Open-Orgbro-GMAIL/logs/gmail_listener.err</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
